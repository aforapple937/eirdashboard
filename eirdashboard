<script>
/* ═══ EIR DASHBOARD REDESIGN — full business logic preserved ═══ */
const $=id=>document.getElementById(id);
function showToast(m){const t=$('toast');t.textContent=m;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3000);}

// DateUtils (memoised)
const DU={months:{"JAN":0,"FEB":1,"MAR":2,"APR":3,"MAY":4,"JUN":5,"JUL":6,"AUG":7,"SEP":8,"OCT":9,"NOV":10,"DEC":11},mn:["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"],_c:{},
  parse(s){if(!s)return null;if(this._c[s]!==undefined)return this._c[s];let r=null;if(s.length>=9){const d=s.substring(0,2),mo=s.substring(2,5).toUpperCase(),y=s.substring(5,9);if(!isNaN(d)&&this.months[mo]!==undefined&&!isNaN(y))r=new Date(parseInt(y),this.months[mo],parseInt(d));}if(!r){const f=new Date(s);r=isNaN(f.getTime())?null:f;}this._c[s]=r;return r;},
  fmtM(s){if(!s)return'-';const d=this.parse(s);if(!d)return s;return String(d.getDate()).padStart(2,'0')+this.mn[d.getMonth()]+d.getFullYear();},
  diff(a,b){const x=this.parse(a),y=this.parse(b);if(!x||!y)return 0;return Math.round((y.getFullYear()-x.getFullYear())*12+(y.getMonth()-x.getMonth()));},
  fmtMY(s){const d=this.parse(s);if(!d)return s;return this.mn[d.getMonth()].toUpperCase()+d.getFullYear().toString().substring(2);}
};

const DC={
  'New originations':    {h:['ACCOUNT_NUMBER','LEDGER_BALANCE_AMT','EIR BS','ALLOCATED_COST','EIR P&L'],k:['acc','bal','lcy','alloc','pnl'],f:['t','n','n','n','n']},
  'Current reprice':     {h:['ACCOUNT_NUMBER','REPRICE_DATE','LEDGER_BALANCE_AMT','Prev EIR BS','Curr EIR BS','EIR P&L'],k:['acc','repDate','bal','prevLcy','currLcy','pnl'],f:['t','d','n','n','n','n']},
  'Future reprice':      {h:['ACCOUNT_NUMBER','REPRICE_DATE','LEDGER_BALANCE_AMT','Prev EIR BS','Curr EIR BS','EIR P&L'],k:['acc','repDate','bal','prevLcy','currLcy','pnl'],f:['t','d','n','n','n','n']},
  'Repriced accounts':   {h:['ACCOUNT_NUMBER','REPRICE_DATE','LEDGER_BALANCE_AMT','Prev EIR BS','Curr EIR BS','EIR P&L'],k:['acc','repDate','bal','prevLcy','currLcy','pnl'],f:['t','d','n','n','n','n']},
  'AEL maturity changed':{h:['ACCOUNT_NUMBER','Prev AEL_MATURITY_DATE','Curr AEL_MATURITY_DATE','Change (months)','Prev EIR BS','Curr EIR BS','EIR P&L'],k:['acc','prevAel','currAel','diffMonths','prevLcy','currLcy','pnl'],f:['t','d','d','t','n','n','n']},
  'EIR changed':         {h:['ACCOUNT_NUMBER','Prev EIR','Curr EIR','EIR Change','Prev BASE_RT','Curr BASE_RT','BASE_RT Change','Prev EIR BS','Curr EIR BS','EIR P&L'],k:['acc','prevEir','currEir','diffEir','prevBase','currBase','diffBase','prevLcy','currLcy','pnl'],f:['t','r','r','r','r','r','r','n','n','n']},
  'Other BAU':           {h:['ACCOUNT_NUMBER','Prev EIR BS','Curr EIR BS','EIR P&L'],k:['acc','prevLcy','currLcy','pnl'],f:['t','n','n','n']},
  'Closed accounts':     {h:['ACCOUNT_NUMBER','LEDGER_BALANCE_AMT','Prev EIR BS','EIR P&L'],k:['acc','bal','prevLcy','pnl'],f:['t','n','n','n']}
};
const METRICS=['New originations','New Count','New Balance','Current reprice','Reprice Curr Count','Reprice Curr Bal','Future reprice','Reprice Fut Count','Reprice Fut Bal','Repriced Total','AEL maturity changed','EIR changed','Other BAU','BAU Total','Closed accounts','Closed Count','Closed Balance','Total'];

// State
let gPnl={},gMonths=[],isMil=false,isExpanded=false,soraCi=null;
window.parsedManualDataGlobal={};window.globalAccountData=null;window.globalDates=[];window.modalIndex={};
window.modalRecords=[];window.modalFilteredRecords=[];window.modalCurrentPage=1;window.modalRecordsPerPage=100;window.modalCurrentDriver='';window.modalSortAsc=false;
let _sel=['HL','HP','Others'],_dMo=[],_ytdMo=[],_zc={};
const _mc={};let _ldr=null;

function _reMo(){
  _dMo=gMonths.length>6?gMonths.slice(-6):gMonths;
  if(!_dMo.length){_ytdMo=[];return;}
  const ly=(DU.parse(_dMo[_dMo.length-1])||{getFullYear:()=>0}).getFullYear();
  _ytdMo=gMonths.filter(m=>{const d=DU.parse(m);return d&&d.getFullYear()===ly;});
}
function sYtd(row){if(!row)return 0;let s=0;_ytdMo.forEach(m=>s+=(row[m]||0));return s;}
function _bZc(pr,prods){
  _zc={};const mo=gMonths;const ck=r=>!r||mo.every(m=>Math.abs(r[m]||0)<0.005);
  const ak=[...METRICS,'Change in SORA','Manual adj: Change in AEL','Repriced Total','BAU Total'];
  prods.forEach(p=>ak.forEach(k=>{_zc[p+'|'+k]=ck(pr[p]?.[k]);}));
}
function rz(p,k){return _zc[p+'|'+k]??true;}

// Keyboard shortcuts
window.addEventListener('keydown',e=>{
  if($('modal').classList.contains('open')){if(e.key==='Escape')closeModal();else if(e.key==='ArrowLeft')changePage(-1);else if(e.key==='ArrowRight')changePage(1);return;}
  if(e.target.tagName==='INPUT')return;
  if(e.key==='e'||e.key==='E')toggleAll();
  if(e.key==='m'||e.key==='M'){$('unitToggle').checked=!$('unitToggle').checked;updateDashboardView();}
  if(e.key==='1')_toggleByName('HL');if(e.key==='2')_toggleByName('HP');if(e.key==='3')_toggleByName('Others');
});
