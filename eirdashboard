async _tx(stores,mode,fn){const db=await this.open();return new Promise((res,rej)=>{const tx=db.transaction(stores,mode);const out={v:undefined};fn(s=>tx.objectStore(s),out);tx.oncomplete=()=>res(out.v);tx.onerror=()=>rej(tx.error);tx.onabort=()=>rej(tx.error);});},
