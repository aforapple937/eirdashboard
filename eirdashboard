};

// Manual-button indicator: lights up when any loaded month has missing manual fields
function updateManualIndicator(){
  const dot=$('manualDot'),btn=$('btnManual');if(!dot||!btn)return;
  const dates=Array.from(new Set(window.globalDates||[])).filter(Boolean);
  if(!dates.length){dot.classList.add('hidden');btn.title='Manual Adjustments (U)';return;}
  const required=[['1M SORA - USED'],['1M SORA - ACTUAL'],['HL','Change in SORA'],['HL','Change in AEL'],['HP','Change in SORA'],['HP','Change in AEL'],['Others','Change in SORA'],['Others','Change in AEL']];
  let missing=0;
  dates.forEach(d=>{
    const key=manualKeyForDate(d);const data=(window.parsedManualDataGlobal&&window.parsedManualDataGlobal[key])||{};
    required.forEach(path=>{
      const v=path.length===1?data[path[0]]:(data[path[0]]&&data[path[0]][path[1]]);
      if(v===undefined||v===null||v==='')missing++;
    });
  });
  if(missing>0){dot.classList.remove('hidden');btn.title=`Manual Adjustments (U) — ${missing} unfilled value${missing>1?'s':''}`;}
  else{dot.classList.add('hidden');btn.title='Manual Adjustments (U) — all filled';}
}
window.exportManualJson=async function(opts){
  const rows=await IDB.getAll(IDB.manStore);
  if(!rows.length){if(!opts||!opts.silent)showToast('No manual entries to export.');return;}
  const months={};rows.forEach(r=>{months[r.key]=r.data;});
  const out={generatedAt:new Date().toISOString(),months};
