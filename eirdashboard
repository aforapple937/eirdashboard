    </div>
  </aside>
  <main class="main">
    <div class="table-area" id="fluxView">
      <div class="app-header">
        <div class="view-tabs" id="viewTabs">
          <div class="view-tab on" data-tab="flux" onclick="switchTab('flux')"><span>EIR Flux</span></div>
          <div class="view-tab" data-tab="sora" onclick="switchTab('sora')"><span>SORA Graph</span></div>
          <div style="margin-left:auto;display:flex;align-items:center;gap:6px;">
            <div class="view-tab" onclick="openShortcutsOverlay()" title="Keyboard shortcuts (?)" style="padding:7px 11px;">
              <span style="font-weight:700">?</span>
            </div>
          </div>
        </div>
        <div class="dash-ctrl hidden" id="dashCtrl">
          <div class="dash-grp">
            <span class="dash-lbl">Products</span>
            <div id="pills" style="display:flex;gap:5px;">
              <div class="dash-pill on" data-p="HL" onclick="toggleProd('HL',this)"><span class="dash-pill-dot" style="background:var(--hl)"></span><span>HL</span></div>
              <div class="dash-pill on" data-p="HP" onclick="toggleProd('HP',this)"><span class="dash-pill-dot" style="background:var(--hp)"></span><span>HP</span></div>
              <div class="dash-pill on" data-p="Others" onclick="toggleProd('Others',this)"><span class="dash-pill-dot" style="background:var(--ot)"></span><span>Others</span></div>
            </div>
          </div>
          <div class="dash-grp">
            <span class="dash-lbl">Units</span>
            <span class="dash-unit-lbl on" id="lbl-exact">Exact (S$)</span>
            <label class="switch"><input type="checkbox" id="unitToggle" onchange="updateDashboardView()"><span class="slider"></span></label>
            <span class="dash-unit-lbl" id="lbl-millions">Millions</span>
          </div>
          <div class="dash-grp">
