window.exportFluxToExcel=function(){
  if(!gMonths.length||!_ldr){showToast('No data.');return;}
  const lm=_dMo[_dMo.length-1];const ml=_dMo.map(m=>DU.fmtMY(m));const yl=`YTD (${DU.fmtMY(lm)})`;
  const drs=[{k:'Change in SORA',l:'Change in SORA'},{k:'New originations',l:'New originations'},{k:'Repriced Total',l:'Repriced accounts'},{k:'Current reprice',l:'  Current reprice'},{k:'Future reprice',l:'  Future reprice'},{k:'BAU Total',l:'BAU'},{k:'AEL maturity changed',l:'  AEL maturity changed'},{k:'EIR changed',l:'  EIR changed'},{k:'Other BAU',l:'  Other BAU'},{k:'Closed accounts',l:'Closed accounts'},{k:'Manual adj: Change in AEL',l:'Manual adj: Change in AEL'},{k:'Total',l:'TOTAL'}];
  const fn=v=>Math.abs(v||0)<0.005?'':(v<0?-Math.abs(v):v);const rows=[];
  _sel.forEach(p=>{if(!_ldr[p])return;if(rows.length)rows.push({});drs.forEach(({k,l})=>{const rd=_ldr[p][k];if(!rd)return;if(gMonths.every(m=>Math.abs(rd[m]||0)<0.005))return;const row={Product:p,Driver:l};_dMo.forEach((m,i)=>{row[ml[i]]=fn(rd[m]||0);});row[yl]=fn(sYtd(rd));rows.push(row);});});
  const gr={Product:'Grand Total',Driver:''};_dMo.forEach((m,i)=>{gr[ml[i]]=fn(_ldr['Grand Total'][m]||0);});gr[yl]=fn(sYtd(_ldr['Grand Total']));rows.push(gr);
  const ws=XLSX.utils.json_to_sheet(rows);ws['!cols']=['Product','Driver',...ml,yl].map(x=>({wch:Math.max(x.length+2,14)}));
  const wb=XLSX.utils.book_new();XLSX.utils.book_append_sheet(wb,ws,'EIR Flux');XLSX.writeFile(wb,`EIR_Flux_${DU.fmtMY(lm)}.xlsx`);showToast('Exported ✓');
};

// SORA Chart
window.renderSoraChart=function(){
  Chart.register(ChartDataLabels);const ctx=$('soraChart').getContext('2d');
  const labs=[],dU=[],dA=[];
  _dMo.forEach(m=>{labs.push(DU.fmtMY(m));const match=m.match(/[A-Z]{3}\d{4}/i);const mKey=match?(match[0].substring(0,3)+match[0].substring(5,7)).toUpperCase():m.toUpperCase();let u=0,a=0;if(window.parsedManualDataGlobal[mKey]){const su=window.parsedManualDataGlobal[mKey]['1M SORA - USED'],sa=window.parsedManualDataGlobal[mKey]['1M SORA - ACTUAL'];if(su)u=parseFloat(su.replace(/[^0-9.-]/g,''))||0;if(sa)a=parseFloat(sa.replace(/[^0-9.-]/g,''))||0;}dU.push(u);dA.push(a);});
  if(soraCi)soraCi.destroy();
  soraCi=new Chart(ctx,{type:'line',data:{labels:labs,datasets:[{label:'Used',data:dU,borderColor:'#FDCF0B',backgroundColor:'rgba(0,0,0,0)',borderWidth:2,pointBackgroundColor:'#fff',pointBorderColor:'#FDCF0B',pointBorderWidth:2,pointRadius:4,fill:false,tension:0.4},{label:'Actual',data:dA,borderColor:'rgba(255,255,255,0.45)',backgroundColor:'rgba(0,0,0,0)',borderWidth:2,pointBackgroundColor:'#111',pointBorderColor:'rgba(255,255,255,0.5)',pointBorderWidth:2,pointRadius:4,fill:false,tension:0.4}]},
    options:{responsive:true,maintainAspectRatio:false,layout:{padding:{top:14,right:4,left:4,bottom:2}},
      plugins:{legend:{position:'top',labels:{color:'rgba(255,255,255,0.5)',font:{family:"'DM Sans',sans-serif",size:9,weight:'600'},padding:8,usePointStyle:true,pointStyleWidth:5}},tooltip:{displayColors:false,backgroundColor:'rgba(0,0,0,0.85)',callbacks:{title:()=>null,label:c=>c.dataset.label+': '+c.parsed.y.toFixed(2)+'%'}},datalabels:{display:false}},
      scales:{y:{grid:{color:'rgba(255,255,255,0.05)'},ticks:{color:'rgba(255,255,255,0.35)',font:{size:8,family:"'DM Sans',sans-serif"},callback:v=>v+'%'},border:{color:'transparent'}},x:{grid:{display:false},ticks:{color:'rgba(255,255,255,0.35)',font:{size:8,family:"'DM Sans',sans-serif",weight:'600'}},border:{color:'transparent'}}}}});
};

// Modal
window.sortModalByPnl=function(){window.modalSortAsc=!window.modalSortAsc;$('btnSort').textContent=window.modalSortAsc?'↑ Ascending':'↓ Descending';window.modalRecords.sort((a,b)=>window.modalSortAsc?a.pnl-b.pnl:b.pnl-a.pnl);window.modalFilteredRecords=[...window.modalRecords];window.modalCurrentPage=1;renderModalPage();};
window.filterModal=function(q){q=q.trim().toLowerCase();window.modalFilteredRecords=q?window.modalRecords.filter(r=>String(r.acc).toLowerCase().includes(q)):window.modalRecords.slice();window.modalCurrentPage=1;renderModalPage();};
window.exportModalToExcel=function(){if(!window.modalRecords?.length)return;const cfg=DC[window.modalCurrentDriver];const data=window.modalRecords.map(r=>{const row={};cfg.h.forEach((h,i)=>{const v=r[cfg.k[i]],f=cfg.f[i];row[h]=f==='d'?DU.fmtM(v):f==='r'?fmtR4(v):(v??'-');});return row;});const wb=XLSX.utils.book_new();XLSX.utils.book_append_sheet(wb,XLSX.utils.json_to_sheet(data),"Details");XLSX.writeFile(wb,"Account_Breakdown.xlsx");showToast('Exported ✓');};
window.changePage=function(d){window.modalCurrentPage+=d;renderModalPage();};
window.renderModalPage=function(){
  const recs=window.modalFilteredRecords,drv=window.modalCurrentDriver;
  const tot=Math.ceil(recs.length/window.modalRecordsPerPage)||1;
  window.modalCurrentPage=Math.max(1,Math.min(window.modalCurrentPage,tot));
  $('pageIndicator').textContent=`Page ${window.modalCurrentPage} of ${tot} (${recs.length.toLocaleString()} accounts)`;
  $('btnPrev').disabled=window.modalCurrentPage===1;$('btnNext').disabled=window.modalCurrentPage===tot;
  const start=(window.modalCurrentPage-1)*window.modalRecordsPerPage;const cfg=DC[drv];
  const html=recs.slice(start,start+window.modalRecordsPerPage).map(r=>{const cells=cfg.k.map((k,i)=>{const f=cfg.f[i],v=r[k];if(f==='n')return`<td>${fmtN(v)}</td>`;if(f==='d')return`<td>${DU.fmtM(v)}</td>`;if(f==='r')return`<td>${fmtR4(v)}</td>`;return`<td>${v||'—'}</td>`;}).join('');return`<tr>${cells}</tr>`;}).join('');
  $('mTbody').innerHTML=html;document.querySelector('.m-tw').scrollTop=0;
};
function fmtN(v,d=2){return(parseFloat(v)||0).toLocaleString(undefined,{minimumFractionDigits:d,maximumFractionDigits:d});}
function fmtR4(v){if(v===undefined||v===null||v==='')return'—';return(parseFloat(v)||0).toFixed(4)+'%';}

window.showDetails=function(prod,drv,mo){
  $('mTitle').textContent=`${prod} — ${drv}`;$('mSub').textContent=`Period: ${DU.fmtMY(mo)}`;
  $('mSearch').value='';$('mThead').innerHTML='';$('mTbody').innerHTML='';$('mFt').classList.add('hidden');$('mSum').style.display='none';
  $('modal').classList.add('open');
  $('mTbody').innerHTML=`<tr><td colspan="10" style="text-align:center;padding:28px;color:var(--text-3)">Loading…</td></tr>`;
  setTimeout(()=>{
    const ck=`${prod}|${drv}|${mo}`;
    if(!_mc[ck]){
      const pm=window.globalDates[window.globalDates.indexOf(mo)-1];
      const accs=window.modalIndex[prod][mo][drv]||[];
      _mc[ck]=accs.map(acc=>{
        const ai=window.globalAccountData.get(acc);const cu=ai.data[mo],pv=pm?ai.data[pm]:null;
        let pv2=0;if(cu&&pv)pv2=cu.lcy-pv.lcy;else if(cu&&!pv)pv2=cu.lcy-cu.alloc;else if(!cu&&pv)pv2=-pv.lcy;
        const r={acc,pnl:pv2};
        if(cu){r.bal=cu.bal;r.lcy=cu.lcy;r.alloc=cu.alloc;r.repDate=cu.repriceDate;r.currAel=cu.aelMaturityDate;r.currEir=cu.eirRate;r.currBase=cu.baseRt;r.currLcy=cu.lcy;}
        if(pv){ r.prevLcy=pv.lcy; r.prevAel=pv.aelMaturityDate;r.prevEir=pv.eirRate;r.prevBase=pv.baseRt;}
        if(cu&&pv){if(drv==='AEL maturity changed')r.diffMonths=DU.diff(pv.aelMaturityDate,cu.aelMaturityDate);else if(drv==='EIR changed'){const pR=parseFloat(pv.eirRate)||0,cR=parseFloat(cu.eirRate)||0,pB=parseFloat(pv.baseRt)||0,cB=parseFloat(cu.baseRt)||0;r.diffEir=cR-pR;r.diffBase=cB-pB;}}
        return r;
      });
    }
    window.modalRecords=_mc[ck];window.modalFilteredRecords=[..._mc[ck]];window.modalCurrentDriver=drv;window.modalCurrentPage=1;window.modalSortAsc=false;$('btnSort').textContent='↓ Sort by P&L';
    const recs=window.modalRecords;const tPnl=recs.reduce((s,r)=>s+r.pnl,0);
    const pf=tPnl<0?`(${Math.abs(tPnl).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2})})`:tPnl.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2});
    $('msAcc').textContent=recs.length.toLocaleString();$('msPnl').textContent=pf;$('msPnl').className='ms-val '+(tPnl>=0?'pos-d':'neg-d');$('mSum').style.display='flex';
    const cfg=DC[drv];$('mThead').innerHTML=`<tr>${cfg.h.map(h=>`<th>${h}</th>`).join('')}</tr>`;
    if(!recs.length){$('mTbody').innerHTML=`<tr><td colspan="${cfg.h.length}" style="text-align:center;padding:28px;color:var(--text-3)">No accounts.</td></tr>`;return;}
    $('mFt').classList.remove('hidden');renderModalPage();
  },50);
};
window.closeModal=function(){$('modal').classList.remove('open');};

// Render dashboard
function renderDashboard(pr,mos,sel){
  const tbody=$('tBody');tbody.innerHTML='';
  const hRow=$('tHead');const ul=isMil?'S$ Millions':'S$';const lm=mos[mos.length-1];
  const mH=mos.map(m=>`<th class="col-data">${DU.fmtMY(m)}</th>`).join('');
  hRow.innerHTML=`<th class="cp">Product<br><span style="font-weight:400;font-size:8.5px;opacity:0.35;text-transform:none;letter-spacing:0">${ul}</span></th><th class="cd">Driver</th>${mH}<th class="csp"></th><th class="cy">Y-T-D<br><span style="font-weight:400;font-size:8.5px;opacity:0.5;text-transform:none;letter-spacing:0">${DU.fmtMY(lm)}</span></th>`;

  if(!sel.length){tbody.innerHTML=`<tr><td colspan="${mos.length+4}" style="text-align:center;padding:32px;color:var(--text-3)">No products selected.</td></tr>`;$('tScroll').classList.remove('hidden');$('emptyState').classList.add('hidden');return;}
  $('tScroll').classList.remove('hidden');$('emptyState').classList.add('hidden');

  _bZc(pr,sel);
  const sp='<td class="csp"></td>';const frag=document.createDocumentFragment();
  const ac={'HL':'a-hl','HP':'a-hp','Others':'a-ot'};const bg=['b0','b1','b2'];

  let _cp='';
  function crow(key,label,grp,drv,isF,isL){
    if(rz(_cp,key))return null;
    const b=bg[sel.indexOf(_cp)%3];const tr=document.createElement('tr');
    tr.className=`child-of-${grp} hidden c-row ${b}${isF?' c-1st':''}${isL?' c-lst':''}`;
    tr.innerHTML=[`<td class="cp"></td><td class="cd">${label}</td>`]
      .concat(mos.map(m=>c(pr[_cp][key][m],{prod:_cp,drv,mo:m})))
      .concat([sp,yc(sYtd(pr[_cp][key]))]).join('');
    return tr;
  }

  sel.forEach((prod,idx)=>{
    if(rz(prod,'Total'))return;
    _cp=prod;const b=bg[idx%3];const a=ac[prod]||'a-ot';const di=prod.replace(/\s+/g,'-');
    function mkRow(inner){const tr=document.createElement('tr');tr.className=`${b} ${a}`;tr.innerHTML=inner;return tr;}

    // SORA
    if(!rz(prod,'Change in SORA')){
      frag.appendChild(mkRow([`<td class="cp"><b>${prod}</b></td><td class="cd">Change in SORA</td>`].concat(mos.map(m=>c(pr[prod]['Change in SORA'][m]))).concat([sp,yc(sYtd(pr[prod]['Change in SORA']))]).join('')));
    }
    // New originations
    if(!rz(prod,'New originations')){
      const sp2=rz(prod,'Change in SORA')?prod:'';let yC=0,yB=0;_ytdMo.forEach(m=>{yC+=(pr[prod]['New Count'][m]||0);yB+=(pr[prod]['New Balance'][m]||0);});
      const ySh=`<div class="st-no-${di} hidden cs">Count: ${yC.toLocaleString()}<br>Bal: ${yB.toFixed(1)}m</div>`;
      frag.appendChild(mkRow([`<td class="cp"><b>${sp2}</b></td><td class="cd">New originations <span class="st" onclick="toggleStats(this,'st-no-${di}')" title="Stats">+</span></td>`]
        .concat(mos.map(m=>{const sh=`<div class="st-no-${di} hidden cs">Count: ${(pr[prod]['New Count'][m]||0).toLocaleString()}<br>Bal: ${(pr[prod]['New Balance'][m]||0).toFixed(1)}m</div>`;return cs(pr[prod]['New originations'][m],sh,prod,'New originations',m);}))
        .concat([sp,ycs(sYtd(pr[prod]['New originations']),ySh)]).join('')));
    }
    // Repriced accounts
    if(!rz(prod,'Repriced Total')){
      const sp2=(rz(prod,'New originations')&&rz(prod,'Change in SORA'))?prod:'';const isHL=prod==='HL';
      let yC=0,yB=0;_ytdMo.forEach(m=>{yC+=isHL?(pr[prod]['Reprice Curr Count'][m]||0):((pr[prod]['Reprice Curr Count'][m]||0)+(pr[prod]['Reprice Fut Count'][m]||0));yB+=isHL?(pr[prod]['Reprice Curr Bal'][m]||0):((pr[prod]['Reprice Curr Bal'][m]||0)+(pr[prod]['Reprice Fut Bal'][m]||0));});
      const ySh=`<div class="st-rp-${di} hidden cs">Count: ${yC.toLocaleString()}<br>Bal: ${yB.toFixed(1)}m</div>`;
      frag.appendChild(mkRow([`<td class="cp"><b>${sp2}</b></td><td class="cd">Repriced accounts <span class="eb" id="btn-reprice-${di}" onclick="toggleGroup('reprice-${di}')" title="Expand">+</span> <span class="st" onclick="toggleStats(this,'st-rp-${di}')" title="Stats">+</span></td>`]
        .concat(mos.map(m=>{const cnt=isHL?(pr[prod]['Reprice Curr Count'][m]||0):((pr[prod]['Reprice Curr Count'][m]||0)+(pr[prod]['Reprice Fut Count'][m]||0));const bal=isHL?(pr[prod]['Reprice Curr Bal'][m]||0):((pr[prod]['Reprice Curr Bal'][m]||0)+(pr[prod]['Reprice Fut Bal'][m]||0));const sh=`<div class="st-rp-${di} hidden cs">Count: ${cnt.toLocaleString()}<br>Bal: ${bal.toFixed(1)}m</div>`;return cs(pr[prod]['Repriced Total'][m],sh,prod,'Repriced accounts',m);}))
        .concat([sp,ycs(sYtd(pr[prod]['Repriced Total']),ySh)]).join('')));
      [crow('Current reprice','Current reprice',`reprice-${di}`,'Current reprice',true,rz(prod,'Future reprice')),
       crow('Future reprice','Future reprice',`reprice-${di}`,'Future reprice',rz(prod,'Current reprice'),true)]
      .filter(Boolean).forEach(r=>frag.appendChild(r));
    }
    // BAU
    if(!rz(prod,'BAU Total')){
      const sp2=(rz(prod,'New originations')&&rz(prod,'Repriced Total')&&rz(prod,'Change in SORA'))?prod:'';
      frag.appendChild(mkRow([`<td class="cp"><b>${sp2}</b></td><td class="cd">BAU <span class="eb" id="btn-bau-${di}" onclick="toggleGroup('bau-${di}')" title="Expand">+</span></td>`]
        .concat(mos.map(m=>c(pr[prod]['BAU Total'][m]))).concat([sp,yc(sYtd(pr[prod]['BAU Total']))]).join('')));
      const aZ=rz(prod,'AEL maturity changed'),eZ=rz(prod,'EIR changed'),oZ=rz(prod,'Other BAU');
      [crow('AEL maturity changed','AEL maturity changed',`bau-${di}`,'AEL maturity changed',true,eZ&&oZ),
       crow('EIR changed','EIR changed',`bau-${di}`,'EIR changed',aZ,oZ),
       crow('Other BAU','Other BAU',`bau-${di}`,'Other BAU',aZ&&eZ,true)]
      .filter(Boolean).forEach(r=>frag.appendChild(r));
    }
    // Closed
    if(!rz(prod,'Closed accounts')){
      let yC=0,yB=0;_ytdMo.forEach(m=>{yC+=(pr[prod]['Closed Count'][m]||0);yB+=(pr[prod]['Closed Balance'][m]||0);});
      const ySh=`<div class="st-cl-${di} hidden cs">Count: ${yC.toLocaleString()}<br>Bal: ${yB.toFixed(1)}m</div>`;
      frag.appendChild(mkRow([`<td class="cp"></td><td class="cd">Closed accounts <span class="st" onclick="toggleStats(this,'st-cl-${di}')" title="Stats">+</span></td>`]
        .concat(mos.map(m=>{const sh=`<div class="st-cl-${di} hidden cs">Count: ${(pr[prod]['Closed Count'][m]||0).toLocaleString()}<br>Bal: ${(pr[prod]['Closed Balance'][m]||0).toFixed(1)}m</div>`;return cs(pr[prod]['Closed accounts'][m],sh,prod,'Closed accounts',m);}))
        .concat([sp,ycs(sYtd(pr[prod]['Closed accounts']),ySh)]).join('')));
    }
    // Manual adj
    if(!rz(prod,'Manual adj: Change in AEL')){
      frag.appendChild(mkRow([`<td class="cp"></td><td class="cd">Manual adj: Change in AEL</td>`]
        .concat(mos.map(m=>c(pr[prod]['Manual adj: Change in AEL'][m]))).concat([sp,yc(sYtd(pr[prod]['Manual adj: Change in AEL']))]).join('')));
    }
    // Product total
    const ts=document.createElement('tr');ts.className=`r-sub ${b} ${a}`;
    ts.innerHTML=[`<td class="cp"></td><td class="cd"><b>${prod} Total</b></td>`]
      .concat(mos.map(m=>c(pr[prod]['Total'][m],{bold:true}))).concat([sp,yc(sYtd(pr[prod]['Total']),true)]).join('');
    frag.appendChild(ts);
  });

  // Grand Total
  const tg=document.createElement('tr');tg.className='r-grand';
  tg.innerHTML=[`<td class="cp"><b>Grand Total</b></td><td class="cd"></td>`]
    .concat(mos.map(m=>c(pr['Grand Total'][m],{bold:true}))).concat([sp,yc(sYtd(pr['Grand Total']),true)]).join('');
  frag.appendChild(tg);
  tbody.appendChild(frag);
  if(isExpanded){document.querySelectorAll('.c-row,.cs').forEach(el=>el.classList.remove('hidden'));document.querySelectorAll('.eb,.st').forEach(b=>b.textContent='−');}
}
</script>
