          </div>
          <div class="dash-grp" style="margin-left:auto">
            <button class="dash-btn" onclick="openManualModal()" title="Manual Adjustments" id="btnManual"><span>✎</span> Manual<span class="manual-dot hidden" id="manualDot" title="Unfilled manual values"></span></button>
            <button class="dash-btn" onclick="toggleAll()" id="btnToggleAll" title="Expand All"><span>⊞</span> Expand All</button>
            <button class="dash-btn" onclick="copyTable()" title="Copy Table"><span>⎘</span> Copy</button>
            <button class="dash-btn" onclick="exportFluxToExcel()" title="Export Excel"><span>↓</span> Excel</button>
          </div>
        </div>
      </div>
      <div id="fluxPanel">
        <div class="t-card" id="tCard">
          <div class="empty" id="emptyState">
            <div class="empty-ico">📊</div>
            <h3>No data loaded</h3>
            <p>Click <strong>Load Data</strong> in the top-right (or press <strong>R</strong>) and select this month's account CSV. Press <strong>U</strong> or click <strong>Manual</strong> to key in manual adjustments (SORA, AEL, P&amp;L overrides) — they save to browser storage. Use <strong>[</strong> and <strong>]</strong> to toggle between EIR Flux and SORA tabs. Press <strong>?</strong> for the full keyboard cheatsheet.</p>
          </div>
          <div class="t-scroll hidden" id="tScroll">
            <table id="pnlTable">
              <thead><tr id="tHead"></tr></thead>
              <tbody id="tBody"></tbody>
            </table>
          </div>
        </div>
      </div>
      <div class="sora-view hidden" id="soraView" style="padding:0;">
        <div class="sora-hero">
          <div class="sora-hero-hd">
            <div class="sora-hero-ttl">1M SORA Trend</div>
            <div class="sora-range">
              <span class="sora-range-lbl">Range</span>
              <select class="sora-range-sel" id="soraRangeFrom" onchange="updateSoraRange()" title="First month shown"></select>
              <span class="sora-range-arrow">→</span>
              <select class="sora-range-sel" id="soraRangeTo" onchange="updateSoraRange()" title="Last month shown"></select>
              <button class="sora-range-reset" onclick="resetSoraRange()" title="Show all months">Reset</button>
