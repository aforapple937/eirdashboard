function calcRunEngine(parsedRow,rawRates,deriveEirOn,withCashflow){
const sysPv=parsedRow.nPvCashFlowsEir||0;
const sysUnamrt=parsedRow.nUnamrtFeesEir||0;
const ledger=parsedRow.bal||0;
const alloc=parsedRow.alloc||0;
const targetPV=ledger+alloc;
const ficMis=_cParse(CALC.month);
const rObjs=[];
for(let i=0;i<rawRates.length;i++){
const d=_cParse(rawRates[i].rtEffDte);if(!d)continue;
if(ficMis&&d<ficMis)continue;
rObjs.push({d,nm:new Date(Date.UTC(d.getUTCFullYear(),d.getUTCMonth(),1)),r:rawRates[i].tierIntRt});
}
rObjs.sort((a,b)=>a.d-b.d);
const seen=new Set(),deduped=[];
for(const o of rObjs){const k=o.nm.getUTCFullYear()+'-'+o.nm.getUTCMonth();if(!seen.has(k)){seen.add(k);deduped.push(o);}}
const startDate=_cParse(parsedRow.lastPymDte)||ficMis;
const maturityDate=_cParse(parsedRow.aelMaturityDate);
if(!startDate||!maturityDate)return null;
let current=new Date(startDate.valueOf());
let activeRate=parsedRow.currIntRt||0;
const eirRate=parseFloat(parsedRow.eirRate)||0;
const cirRate=activeRate;
let opening=ledger;const initLedger=ledger;
const installment=parsedRow.pymtRecdCurrMth||0;
const cfEngine=[],cashflow=[];let period=1;
while(current<maturityDate){
let nextStart=_cAddMonth(current),endDate=_cSubDay(nextStart),isLast=false;
if(nextStart>=maturityDate){endDate=_cSubDay(maturityDate);nextStart=new Date(maturityDate.valueOf());isLast=true;}
const startChange=deduped.find(r=>r.nm.getTime()===current.getTime());
if(startChange)activeRate=startChange.r;
let r1=activeRate,r2='',days1=0,days2=0,yf1=0,yf2=0;
const mid=deduped.find(r=>r.nm>current&&r.nm<nextStart);
if(mid){r2=mid.r;days1=_cDD(current,mid.nm);days2=_cDD(mid.nm,nextStart);yf1=_cACT(current,mid.nm);yf2=_cACT(mid.nm,nextStart);}
else{days1=_cDD(current,nextStart);yf1=_cACT(current,nextStart);}
const rr1=parseFloat(r1)||0,rr2=parseFloat(r2)||0;
const interest=(opening*(rr1/100)*yf1)+(opening*(rr2/100)*yf2);
let principal=installment-interest;let ending=opening-principal;
if(ending<0||isLast){principal=opening;ending=0;}
const cf=principal+interest;
const endPlus=new Date(endDate.valueOf());endPlus.setUTCDate(endPlus.getUTCDate()+1);
const A=_cDD(startDate,endPlus),B=_cDIY(endDate.getUTCFullYear()),n=A/B;
cfEngine.push({cf,n});
if(withCashflow)cashflow.push({period,startDate:_cFmt(current),endDate:_cFmt(endDate),rate1:rr1,rate2:r2===''?'':rr2,days1,days2,yf1,yf2,opening,interest,principal,ending,cf,df:0,pv:0});
opening=ending;if(mid)activeRate=rr2;
if(isLast)break;
current=new Date(nextStart.valueOf());period++;
}
let workEir=eirRate;
if(deriveEirOn){
let lo=0,hi=5,best=eirRate/100,tol=0.001;
for(let i=0;i<100;i++){
const g=(lo+hi)/2;let tp=0;for(let j=0;j<cfEngine.length;j++)tp+=cfEngine[j].cf/Math.pow(1+g,cfEngine[j].n);
if(Math.abs(tp-targetPV)<tol){best=g;break;}
if(tp>targetPV)lo=g;else hi=g;
}
workEir=best*100;
}
let pvCalc=0;
for(let i=0;i<cfEngine.length;i++){
const df=1/Math.pow(1+workEir/100,cfEngine[i].n);
const pv=cfEngine[i].cf*df;
pvCalc+=pv;
if(withCashflow){cashflow[i].df=df;cashflow[i].pv=pv;}
}
const nAct=ficMis?_cACT(startDate,ficMis):0;
const eirInterest=pvCalc*(workEir/100)*nAct;
const cirInterest=initLedger*(cirRate/100)*nAct;
const eirAdj=pvCalc-initLedger+eirInterest-cirInterest;
const pvDiff=pvCalc-sysPv,pvDiffPct=sysPv!==0?(pvDiff/sysPv)*100:0;
const eirDiff=eirAdj-sysUnamrt,eirDiffPct=sysUnamrt!==0?(eirDiff/sysUnamrt)*100:0;
return{cashflow,pvCalc,pvSys:sysPv,pvDiff,pvDiffPct,eirAdjCalc:eirAdj,eirAdjSys:sysUnamrt,eirDiff,eirDiffPct,derivedEir:workEir,sysEir:eirRate,eirRateDiff:workEir-eirRate};
}
