window.toggleProd=function(p,el){
  const i=_sel.indexOf(p);if(i>=0){if(_sel.length===1)return;_sel.splice(i,1);el.classList.remove('on');}else{_sel.push(p);el.classList.add('on');}updateDashboardView();
};

// File loading
$('navFile').addEventListener('change',function(e){
  const files=Array.from(e.target.files);if(!files.length)return;
  $('ldOv').classList.remove('hidden');$('emptyState').classList.add('hidden');
  const accountData=new Map(),datesSet=new Set();window.parsedManualDataGlobal={};
  let filesDone=0,bytesProcessed=0;const totalBytes=files.reduce((s,f)=>s+f.size,0);
  files.forEach(file=>{
    let lastCursor=0;
    Papa.parse(file,{header:true,skipEmptyLines:true,
      chunk(results){
        if(!results.data.length)return;
        const cursor=results.meta.cursor||0;bytesProcessed+=(cursor-lastCursor);lastCursor=cursor;
        const pct=Math.min((bytesProcessed/totalBytes)*100,99);
        $('progressBar').style.width=pct+'%';$('progressText').textContent=`Reading files… ${Math.round(pct)}%`;
        if(results.meta.fields.includes('ACCOUNT_NUMBER')){
          results.data.forEach(row=>{
            const acc=row.ACCOUNT_NUMBER,date=row.FIC_MIS_DATE;if(!acc||!date)return;
            datesSet.add(date);if(!accountData.has(acc))accountData.set(acc,{product:'Others',data:{}});
            const ai=accountData.get(acc);
            if(row.V_AEL_GROUP_ID==='SG_Housing')ai.product='HL';else if(row.V_AEL_GROUP_ID==='SG_HirePurchase')ai.product='HP';
            let rY=null,rM=null;if(row.REPRICE_DATE){const rd=DU.parse(row.REPRICE_DATE);if(rd){rY=rd.getFullYear();rM=rd.getMonth();}}
            ai.data[date]={lcy:parseFloat(row.LCY_EIR_ADJ_AMT)||0,alloc:parseFloat(row.ALLOCATED_COST)||0,repriceDate:row.REPRICE_DATE,rYear:rY,rMonth:rM,aelMaturityDate:row.AEL_MATURITY_DATE,eirRate:row.N_IFRS9_EFF_INTEREST_RATE,baseRt:parseFloat(row.BASE_RT)||0,bal:parseFloat(row.LEDGER_BALANCE_AMT)||0};
          });
        } else if(results.meta.fields.includes('FIELD')&&results.meta.fields.includes('VALUE')){
          results.data.forEach(row=>{
            const rd=row.DATE,field=row.FIELD,prod=row.PRODUCT,vs=row.VALUE,val=parseFloat(vs)||0;if(!rd||!field)return;
            const parts=rd.split('-');let mKey=rd.toUpperCase();if(parts.length===3)mKey=(parts[1]+parts[2]).toUpperCase();
            const cf=String(field).trim();if(!window.parsedManualDataGlobal[mKey])window.parsedManualDataGlobal[mKey]={};
            if(cf==='1M SORA - USED'||cf==='1M SORA - ACTUAL'){window.parsedManualDataGlobal[mKey][cf]=vs;return;}
            if(!prod)return;let cp=String(prod).trim();
            if(cp==='SG_Housing'||cp==='HL')cp='HL';else if(cp==='SG_HirePurchase'||cp==='HP')cp='HP';else cp='Others';
            if(!window.parsedManualDataGlobal[mKey][cp])window.parsedManualDataGlobal[mKey][cp]={};
            window.parsedManualDataGlobal[mKey][cp][cf]=val;
          });
        }
      },
      complete(){filesDone++;if(filesDone===files.length){$('progressBar').style.width='100%';$('progressText').textContent='Crunching numbers…';window.globalAccountData=accountData;setTimeout(()=>processData(accountData,Array.from(datesSet)),50);}}
    });
  });
});

function processData(accountData,dates){
  dates.sort((a,b)=>DU.parse(a)-DU.parse(b));window.globalDates=dates;
  const rm=dates.slice(1),prods=['HL','HP','Others'];const pr={};window.modalIndex={};
  prods.forEach(p=>{pr[p]={};window.modalIndex[p]={};METRICS.forEach(m=>{pr[p][m]={};rm.forEach(mo=>pr[p][m][mo]=0);});rm.forEach(m=>window.modalIndex[p][m]={});});
  function idx(p,mo,dr,ac){if(!window.modalIndex[p][mo][dr])window.modalIndex[p][mo][dr]=[];window.modalIndex[p][mo][dr].push(ac);}
  for(let i=1;i<dates.length;i++){
    const cm=dates[i],pm=dates[i-1];const fdo=DU.parse(cm);const fy=fdo?fdo.getFullYear():0,fm=fdo?fdo.getMonth():0;
    for(const[acc,ai]of accountData.entries()){
      const p=ai.product,dm=ai.data;const cu=dm[cm],pv=dm[pm];
      let pv2=0,isN=false,isCl=false;
      if(cu&&pv)pv2=cu.lcy-pv.lcy;else if(cu&&!pv){pv2=cu.lcy-cu.alloc;isN=true;}else if(!cu&&pv){pv2=-pv.lcy;isCl=true;}else continue;
      if(isCl){pr[p]['Closed accounts'][cm]+=pv2;pr[p]['Closed Count'][cm]++;pr[p]['Closed Balance'][cm]+=pv.bal;idx(p,cm,'Closed accounts',acc);continue;}
      let isCR=false,iFR=false,isA=false,isE=false;
      if(cu.rYear!==null&&fdo){if(fy===cu.rYear&&fm===cu.rMonth)isCR=true;else if(cu.rYear>fy||(cu.rYear===fy&&cu.rMonth>fm))iFR=true;}
      if(cu&&pv&&cu.aelMaturityDate!==pv.aelMaturityDate)isA=true;
      if(cu&&pv&&cu.eirRate!==pv.eirRate&&cu.eirRate!==undefined&&pv.eirRate!==undefined)isE=true;
      if(isCR){pr[p]['Current reprice'][cm]+=pv2;pr[p]['Repriced Total'][cm]+=pv2;pr[p]['Reprice Curr Count'][cm]++;pr[p]['Reprice Curr Bal'][cm]+=cu.bal;idx(p,cm,'Current reprice',acc);idx(p,cm,'Repriced accounts',acc);}
      else if(iFR){pr[p]['Future reprice'][cm]+=pv2;pr[p]['Repriced Total'][cm]+=pv2;pr[p]['Reprice Fut Count'][cm]++;pr[p]['Reprice Fut Bal'][cm]+=cu.bal;idx(p,cm,'Future reprice',acc);idx(p,cm,'Repriced accounts',acc);}
      else if(isN){pr[p]['New originations'][cm]+=pv2;pr[p]['New Count'][cm]++;pr[p]['New Balance'][cm]+=cu.bal;idx(p,cm,'New originations',acc);}
      else if(isA){pr[p]['AEL maturity changed'][cm]+=pv2;pr[p]['BAU Total'][cm]+=pv2;idx(p,cm,'AEL maturity changed',acc);}
      else if(isE){pr[p]['EIR changed'][cm]+=pv2;pr[p]['BAU Total'][cm]+=pv2;idx(p,cm,'EIR changed',acc);}
      else{pr[p]['Other BAU'][cm]+=pv2;pr[p]['BAU Total'][cm]+=pv2;idx(p,cm,'Other BAU',acc);}
    }
  }
  rm.forEach(m=>prods.forEach(p=>{pr[p]['Total'][m]=pr[p]['New originations'][m]+pr[p]['Repriced Total'][m]+pr[p]['BAU Total'][m]+pr[p]['Closed accounts'][m];}));
  gPnl=pr;gMonths=rm;_reMo();
  $('ldOv').classList.add('hidden');
  updateDashboardView();renderSoraChart();
  $('soraSec').classList.remove('hidden');$('kpiSec').style.display='';
  const lm=_dMo[_dMo.length-1];if(lm){$('navPeriod').textContent='Latest: '+DU.fmtMY(lm);$('navPeriod').style.display='';}
  $('tbSub').textContent=_dMo.length+' months · click any value to drill down';
}

function gdv(v){if(!v)return 0;return isMil?Math.round(v/100000)/10:v;}

window.updateDashboardView=function(){
  isMil=$('unitToggle').checked;
  $('lbl-exact').className='unit-lbl'+(isMil?'':' on');
  $('lbl-millions').className='unit-lbl'+(isMil?' on':'');
  if(!gMonths.length)return;
  const dr={'Grand Total':{}};gMonths.forEach(m=>dr['Grand Total'][m]=0);
  _sel.forEach(p=>{
    dr[p]={};gMonths.forEach(m=>{
      const match=m.match(/[A-Z]{3}\d{4}/i);const mKey=match?(match[0].substring(0,3)+match[0].substring(5,7)).toUpperCase():m.toUpperCase();
      let ms=0,ma=0,mp=undefined;
      if(window.parsedManualDataGlobal?.[mKey]?.[p]){ms=window.parsedManualDataGlobal[mKey][p]['Change in SORA']||0;ma=window.parsedManualDataGlobal[mKey][p]['Change in AEL']||0;if(window.parsedManualDataGlobal[mKey][p]['P&L']!==undefined)mp=window.parsedManualDataGlobal[mKey][p]['P&L'];}
      const eN=gPnl[p]['New originations'][m]||0,eRC=gPnl[p]['Current reprice'][m]||0,eRF=gPnl[p]['Future reprice'][m]||0,eA=gPnl[p]['AEL maturity changed'][m]||0,eE=gPnl[p]['EIR changed'][m]||0,eCl=gPnl[p]['Closed accounts'][m]||0;
      const dN=gdv(eN),dRC=gdv(eRC),dRF=gdv(eRF),dA=gdv(eA),dE=gdv(eE),dCl=gdv(eCl),dS=gdv(ms),dMA=gdv(ma),dEA=dE-dS,dRT=dRC+dRF;
      const dT=mp!==undefined?gdv(mp)+dMA:gdv(gPnl[p]['Total'][m]||0)+dMA;
      const dOB=dT-dS-dN-dRT-dA-dEA-dCl-dMA,dBT=dA+dEA+dOB;
      const set=(k,v)=>{if(!dr[p][k])dr[p][k]={};dr[p][k][m]=v;};
      set('Total',dT);set('Change in SORA',dS);set('New originations',dN);set('Current reprice',dRC);set('Future reprice',dRF);set('Repriced Total',dRT);set('AEL maturity changed',dA);set('EIR changed',dEA);set('Other BAU',dOB);set('BAU Total',dBT);set('Closed accounts',dCl);set('Manual adj: Change in AEL',dMA);
      const bs=1000000;dr[p]['New Count']=gPnl[p]['New Count'];set('New Balance',(gPnl[p]['New Balance'][m]||0)/bs);
      dr[p]['Reprice Curr Count']=gPnl[p]['Reprice Curr Count'];dr[p]['Reprice Fut Count']=gPnl[p]['Reprice Fut Count'];dr[p]['Closed Count']=gPnl[p]['Closed Count'];
      set('Reprice Curr Bal',(gPnl[p]['Reprice Curr Bal'][m]||0)/bs);set('Reprice Fut Bal',(gPnl[p]['Reprice Fut Bal'][m]||0)/bs);set('Closed Balance',(gPnl[p]['Closed Balance'][m]||0)/bs);
      dr['Grand Total'][m]+=dT;
    });
  });
  _reMo();_ldr=dr;
  _upKpi(dr);_upPills(dr);
  renderDashboard(dr,_dMo,_sel);
};

function _upKpi(dr){
  const lm=_dMo[_dMo.length-1];if(!lm)return;
  const gt=dr['Grand Total'][lm]||0,prev=_dMo.length>=2?dr['Grand Total'][_dMo[_dMo.length-2]]||0:null;
  const fmt=v=>{const s=Math.abs(v).toLocaleString(undefined,{minimumFractionDigits:isMil?1:0,maximumFractionDigits:isMil?1:0});return v<0?`(${s})`:s;};
  const ytdGT=sYtd(dr['Grand Total']);
  let h=`<div class="kpi-card"><div class="kpi-lbl">Grand Total — ${DU.fmtMY(lm)}</div><div class="kpi-val ${gt>=0?'pos':'neg'}">${fmt(gt)}</div>${prev!==null?`<div class="kpi-sub">vs prior: <span class="${(gt-prev)>=0?'pos':'neg'}">${gt-prev>=0?'+':''}${fmt(gt-prev)}</span></div>`:''}</div>`;
  h+=`<div class="kpi-card"><div class="kpi-lbl">Y-T-D ${DU.fmtMY(lm)}</div><div class="kpi-val ${ytdGT>=0?'pos':'neg'}">${fmt(ytdGT)}</div></div>`;
  $('kpiGrid').innerHTML=h;
}
function _upPills(dr){
  const lm=_dMo[_dMo.length-1];if(!lm)return;
  const pairs=[['HL','pt-HL'],['HP','pt-HP'],['Others','pt-Ot']];
  pairs.forEach(([p,id])=>{const el=$(id);if(!el)return;const v=dr[p]?.['Total']?.[lm]??null;if(v===null){el.textContent='—';return;}const s=Math.abs(v).toLocaleString(undefined,{minimumFractionDigits:1,maximumFractionDigits:1});el.textContent=v<0?`(${s})`:s;el.className='pill-tot '+(v>=0?'pos':'neg');});
}

