// File loading — group by FIC_MIS_DATE, persist per-month to IndexedDB, rebuild from store.
// Accepts account-row CSVs (header ACCOUNT_NUMBER) and manual-adjustment JSON files ({months:{KEY:{...}}}).
$('navFile').addEventListener('change',async function(e){
  const files=Array.from(e.target.files);if(!files.length)return;
  $('ldOv').classList.remove('hidden');$('emptyState').classList.add('hidden');
  const accBuckets={},manBuckets={};
  const csvFiles=files.filter(f=>!/\.json$/i.test(f.name));
  const jsonFiles=files.filter(f=>/\.json$/i.test(f.name));
  let bytesProcessed=0;const totalBytes=csvFiles.reduce((s,f)=>s+f.size,0)||1;
  await Promise.all(csvFiles.map(file=>new Promise(resolve=>{
    let lastCursor=0;
    Papa.parse(file,{header:true,skipEmptyLines:true,
      chunk(results){
        if(!results.data.length)return;
        const cursor=results.meta.cursor||0;bytesProcessed+=(cursor-lastCursor);lastCursor=cursor;
        const pct=Math.min((bytesProcessed/totalBytes)*100,99);
        $('progressBar').style.width=pct+'%';$('progressText').textContent=`Reading files… ${Math.round(pct)}%`;
        if(results.meta.fields.includes('ACCOUNT_NUMBER')){
          results.data.forEach(row=>{
            const acc=row.ACCOUNT_NUMBER,date=row.FIC_MIS_DATE;if(!acc||!date)return;
            let prod='Others';
            if(row.V_AEL_GROUP_ID==='SG_Housing')prod='HL';else if(row.V_AEL_GROUP_ID==='SG_HirePurchase')prod='HP';
            let rY=null,rM=null;if(row.REPRICE_DATE){const rd=DU.parse(row.REPRICE_DATE);if(rd){rY=rd.getFullYear();rM=rd.getMonth();}}
            if(!accBuckets[date])accBuckets[date]=[];
            accBuckets[date].push({acc,product:prod,lcy:parseFloat(row.LCY_EIR_ADJ_AMT)||0,alloc:parseFloat(row.ALLOCATED_COST)||0,repriceDate:row.REPRICE_DATE,rYear:rY,rMonth:rM,aelMaturityDate:row.AEL_MATURITY_DATE,eirRate:row.N_IFRS9_EFF_INTEREST_RATE,baseRt:parseFloat(row.BASE_RT)||0,bal:parseFloat(row.LEDGER_BALANCE_AMT)||0});
          });
        }
      },
      complete(){resolve();},
      error(){resolve();}
    });
  })));
  for(const file of jsonFiles){
    try{
      const txt=await file.text();const obj=JSON.parse(txt);
      const months=obj&&obj.months?obj.months:obj;
      if(months&&typeof months==='object'){
        Object.entries(months).forEach(([k,v])=>{if(v&&typeof v==='object')manBuckets[String(k).toUpperCase()]=v;});
      }
    }catch(err){console.error('Bad manual JSON',file.name,err);showToast('Skipped invalid JSON: '+file.name);}
  }
  $('navFile').value='';
  $('progressText').textContent='Saving to browser storage…';$('progressBar').style.width='100%';
  const savedAcc=Object.keys(accBuckets),savedMan=Object.keys(manBuckets);
  try{
    for(const[date,rows]of Object.entries(accBuckets))await IDB.putAcc(date,rows);
    for(const[key,data]of Object.entries(manBuckets))await IDB.putMan(key,data);
  }catch(err){console.error(err);showToast('Save failed: '+err.message);}
  await rebuildFromStore();
  if(savedAcc.length||savedMan.length){
    const parts=[];if(savedAcc.length)parts.push(savedAcc.length+' account month'+(savedAcc.length>1?'s':''));if(savedMan.length)parts.push(savedMan.length+' manual month'+(savedMan.length>1?'s':''));
    showToast('Saved '+parts.join(' + ')+' ✓');
  }
});

async function rebuildFromStore(){
  const[accRows,manRows]=await Promise.all([IDB.getAll(IDB.accStore),IDB.getAll(IDB.manStore)]);
  const accountData=new Map();const datesSet=new Set();
  for(const entry of accRows){
    datesSet.add(entry.date);
    for(const row of entry.rows){
      if(!accountData.has(row.acc))accountData.set(row.acc,{product:row.product||'Others',data:{}});
      const ai=accountData.get(row.acc);
      if(row.product&&row.product!=='Others')ai.product=row.product;
      ai.data[entry.date]={lcy:row.lcy,alloc:row.alloc,repriceDate:row.repriceDate,rYear:row.rYear,rMonth:row.rMonth,aelMaturityDate:row.aelMaturityDate,eirRate:row.eirRate,baseRt:row.baseRt,bal:row.bal};
    }
  }
  window.parsedManualDataGlobal={};
  for(const m of manRows)window.parsedManualDataGlobal[m.key]=m.data;
  window.globalAccountData=accountData;
  Object.keys(_mc).forEach(k=>delete _mc[k]);
  await renderStoredMonthsPanel();
  if(!accountData.size){
    $('ldOv').classList.add('hidden');
    $('emptyState').classList.remove('hidden');$('tScroll').classList.add('hidden');
    $('dashCtrl').style.display='none';
    gPnl={};gMonths=[];window.globalDates=[];_ldr=null;_userRange=null;
    if(typeof updateManualIndicator==='function')updateManualIndicator();
    return;
  }
  $('progressText').textContent='Crunching numbers…';
  await new Promise(r=>setTimeout(()=>{processData(accountData,Array.from(datesSet));r();},30));
  if(datesSet.size<2)showToast('Only '+datesSet.size+' month stored — upload the prior month to enable flux comparison.');
}

