<script>
/* ═══ EIR DASHBOARD REDESIGN — full business logic preserved ═══ */
const $=id=>document.getElementById(id);
function showToast(m){const t=$('toast');t.textContent=m;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3000);}

// DateUtils (memoised)
const DU={months:{"JAN":0,"FEB":1,"MAR":2,"APR":3,"MAY":4,"JUN":5,"JUL":6,"AUG":7,"SEP":8,"OCT":9,"NOV":10,"DEC":11},mn:["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"],_c:{},
  parse(s){if(!s)return null;if(this._c[s]!==undefined)return this._c[s];let r=null;if(s.length>=9){const d=s.substring(0,2),mo=s.substring(2,5).toUpperCase(),y=s.substring(5,9);if(!isNaN(d)&&this.months[mo]!==undefined&&!isNaN(y))r=new Date(parseInt(y),this.months[mo],parseInt(d));}if(!r){const f=new Date(s);r=isNaN(f.getTime())?null:f;}this._c[s]=r;return r;},
  fmtM(s){if(!s)return'-';const d=this.parse(s);if(!d)return s;return String(d.getDate()).padStart(2,'0')+this.mn[d.getMonth()]+d.getFullYear();},
  diff(a,b){const x=this.parse(a),y=this.parse(b);if(!x||!y)return 0;return Math.round((y.getFullYear()-x.getFullYear())*12+(y.getMonth()-x.getMonth()));},
  fmtMY(s){const d=this.parse(s);if(!d)return s;return this.mn[d.getMonth()].toUpperCase()+d.getFullYear().toString().substring(2);}
};

// IndexedDB: persist per-month account rows & manual-adj data so users top up one month at a time
const IDB={name:'eirdashboard_v1',version:1,accStore:'accountMonths',manStore:'manualMonths',_p:null,
  open(){if(this._p)return this._p;this._p=new Promise((res,rej)=>{const r=indexedDB.open(this.name,this.version);r.onupgradeneeded=e=>{const db=e.target.result;if(!db.objectStoreNames.contains(this.accStore))db.createObjectStore(this.accStore,{keyPath:'date'});if(!db.objectStoreNames.contains(this.manStore))db.createObjectStore(this.manStore,{keyPath:'key'});};r.onsuccess=()=>res(r.result);r.onerror=()=>rej(r.error);});return this._p;},
  async putAcc(date,rows){const db=await this.open();return new Promise((res,rej)=>{const tx=db.transaction(this.accStore,'readwrite');tx.objectStore(this.accStore).put({date,rows,savedAt:Date.now()});tx.oncomplete=()=>res();tx.onerror=()=>rej(tx.error);});},
  async putMan(key,data){const db=await this.open();return new Promise((res,rej)=>{const tx=db.transaction(this.manStore,'readwrite');tx.objectStore(this.manStore).put({key,data,savedAt:Date.now()});tx.oncomplete=()=>res();tx.onerror=()=>rej(tx.error);});},
  async getAll(store){const db=await this.open();return new Promise((res,rej)=>{const tx=db.transaction(store,'readonly');const r=tx.objectStore(store).getAll();r.onsuccess=()=>res(r.result||[]);r.onerror=()=>rej(r.error);});},
  async del(store,key){const db=await this.open();return new Promise((res,rej)=>{const tx=db.transaction(store,'readwrite');tx.objectStore(store).delete(key);tx.oncomplete=()=>res();tx.onerror=()=>rej(tx.error);});},
  async clearAll(){const db=await this.open();return new Promise((res,rej)=>{const tx=db.transaction([this.accStore,this.manStore],'readwrite');tx.objectStore(this.accStore).clear();tx.objectStore(this.manStore).clear();tx.oncomplete=()=>res();tx.onerror=()=>rej(tx.error);});}
};

