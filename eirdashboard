// Format
function fv(v){if(!v)v=0;const dp=isMil?1:2;const s=Math.abs(v).toLocaleString(undefined,{minimumFractionDigits:dp,maximumFractionDigits:dp});return v<0?`(${s})`:s;}
function c(v,o={}){
  const{bold:b=false,ytd=false,prod=null,drv=null,mo=null,stats=''}=o;
  const yc=ytd?' cy':'';const cl=(prod&&drv&&mo)?` onclick="showDetails('${prod}','${drv}','${mo}')"` :'';const cc=cl?' cc':'';
  if(Math.abs(v||0)<0.005)return`<td class="${(yc+cc).trim()}"${cl}>${b?'<b>—</b>':'—'}${stats}</td>`;
  const cls=v>=0?'pos-d':'neg-d';const cnt=b?`<b>${fv(v)}</b>`:fv(v);
  return`<td class="${cls}${yc}${cc}"${cl}>${cnt}${stats}</td>`;
}
function yc(v,b=false){return c(v,{bold:b,ytd:true});}
function ycs(v,s){return c(v,{ytd:true,stats:s});}
function cs(v,s,p=null,d=null,m=null){return c(v,{prod:p,drv:d,mo:m,stats:s});}

