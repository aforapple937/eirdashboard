    <div class="p-track"><div class="p-fill" id="progressBar"></div></div>
  </div>
</div>
</div>
<div class="app">
  <aside class="sidebar" id="sidebar">
    <div class="sb-modules">
      <div class="sb-module active" data-mod="flux" onclick="switchModule('flux')"><span class="sb-module-left"><span class="sb-module-ico"></span>EIR FLUX</span></div>
