            <select class="dash-range-sel" id="calcMonth" onchange="calcOnMonthChange()" title="Select a month to calculate"></select>
          </div>
          <div class="dash-grp">
            <span class="dash-lbl">Account</span>
            <input type="text" id="calcAcc" placeholder="Account Number" style="padding:5px 10px;border:1.5px solid var(--border);border-radius:var(--r);font-family:var(--font);font-size:11.5px;font-weight:600;color:var(--text-1);background:var(--surface-2);outline:none;width:180px;">
          </div>
          <div class="dash-grp">
            <span class="dash-lbl">Options</span>
            <label class="dash-pill" style="cursor:pointer;" title="Re-derive EIR via goal-seek"><input type="checkbox" id="calcDerive" style="margin:0;accent-color:var(--yellow-dk);"> Re-Derive EIR</label>
          </div>
