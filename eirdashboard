const deriveEirOn=CALC.method==='derive';
const rates=CALC.rateByAcc.get(acc)||[];
const res=calcRunEngine(row,rates,deriveEirOn,true);
if(!res){showToast('Missing LAST_PYM_DTE or AEL_MATURITY_DATE for '+acc+'.');return;}
CALC.currentAcc=acc;CALC.lastResult=res;CALC.singleMethod=CALC.method;
$('calcDrillAcc').textContent=acc;
$('calcDrillMeta').innerHTML=`<span>${deriveEirOn?'Re-derive EIR':'System EIR'}</span>`;
calcRenderRecon('calcSingleReconBody',res,deriveEirOn,CALC.method);
calcRenderCashflow(res.cashflow,res.pvCalc);
calcShowView('single');
}
window.calcBackFromSingle=function(){
if(CALC.portfolio.length){calcShowView('portfolio');}
else{calcShowEmpty();}
};
window.calcCloseNegEirModal=function(){$('calcNegEirModal').classList.remove('open');};
window.calcCloseExcludedModal=function(){$('calcExcludedModal').classList.remove('open');};
function calcRunAll(){
if(CALC.running)return;
CALC.running=true;CALC.cancelled=false;
const deriveEirOn=CALC.method==='derive';
const accs=Array.from(CALC.accByNum.entries());
const total=accs.length;let idx=0;const batch=200;
CALC.portfolio=[];CALC.negativeEir=[];CALC.excludedFlag=[];CALC.excludedHP=[];
CALC.startedAt=Date.now();
$('calcProgTitle').textContent=deriveEirOn?'Calculating all accounts · Re-derive EIR':'Calculating all accounts · System EIR';
calcUpdateProgress(0,total);
calcShowView('progress');
let gPv=0,gPvSys=0,gEir=0,gEirSys=0;
function step(){
if(CALC.cancelled){CALC.running=false;CALC.cancelled=false;calcShowEmpty();showToast('Calculation cancelled');return;}
const end=Math.min(idx+batch,total);
for(let i=idx;i<end;i++){
const[acc,row]=accs[i];
if(row.groupId==='SG_HirePurchase'){CALC.excludedHP.push(acc);continue;}
if(deriveEirOn&&row.fEirFlag!=='Y'){CALC.excludedFlag.push(acc);continue;}
const eirVal=parseFloat(row.eirRate)||0;
if(eirVal<0){CALC.negativeEir.push(acc);continue;}
const rates=CALC.rateByAcc.get(acc)||[];
const res=calcRunEngine(row,rates,deriveEirOn,false);
if(!res)continue;
CALC.portfolio.push({acc,pvCalc:res.pvCalc,pvSys:res.pvSys,pvDiff:res.pvDiff,pvDiffPct:res.pvDiffPct,eirAdjCalc:res.eirAdjCalc,eirAdjSys:res.eirAdjSys,eirDiff:res.eirDiff,eirDiffPct:res.eirDiffPct,derivedEir:res.derivedEir,sysEir:res.sysEir,eirRateDiff:res.eirRateDiff});
gPv+=res.pvCalc;gPvSys+=res.pvSys;gEir+=res.eirAdjCalc;gEirSys+=res.eirAdjSys;
}
idx=end;calcUpdateProgress(idx,total);
if(idx<total){setTimeout(step,0);return;}
CALC.running=false;
const _r2p=v=>Math.round((v||0)*100)/100;
const gPvR=_r2p(gPv),gPvSysR=_r2p(gPvSys);
const gPvDiff=_r2p(gPvR-gPvSysR),gPvDiffPct=gPvSysR!==0?(gPvDiff/gPvSysR)*100:0;
const gEirR=_r2p(gEir),gEirSysR=_r2p(gEirSys);
const gEirDiff=_r2p(gEirR-gEirSysR),gEirDiffPct=gEirSysR!==0?(gEirDiff/gEirSysR)*100:0;
CALC.portfolioTotals={pvCalc:gPv,pvSys:gPvSys,pvDiff:gPvDiff,pvDiffPct:gPvDiffPct,eirAdjCalc:gEir,eirAdjSys:gEirSys,eirDiff:gEirDiff,eirDiffPct:gEirDiffPct,derivedEir:0,sysEir:0,eirRateDiff:0};
CALC.resultMethod=CALC.method;
CALC.page=1;CALC.sort={field:null,dir:1};
calcRenderPortfolioResults();
calcShowView('portfolio');
$('btnCalcExport').classList.remove('hidden');
}
setTimeout(step,0);
}
window.calcCancelRun=function(){if(CALC.running)CALC.cancelled=true;};
function calcUpdateProgress(done,total){
const pct=total?Math.floor((done/total)*100):0;
$('calcProgPct').textContent=pct+'%';
$('calcProgBarFill').style.width=pct+'%';
$('calcProgCount').textContent=`${done.toLocaleString()} of ${total.toLocaleString()} accounts`;
const eta=$('calcProgEta');
if(done<500||done===total){eta.innerHTML='&nbsp;';return;}
const elapsed=(Date.now()-CALC.startedAt)/1000;
const remaining=Math.max(0,elapsed*(total-done)/done);
eta.textContent=remaining<1?'< 1 second remaining':('~'+Math.ceil(remaining)+' second'+(remaining>=2?'s':'')+' remaining');
}
function calcRenderPortfolioResults(){
calcRenderCoverage();
const rm=CALC.resultMethod||CALC.method;
$('calcPortReconTitle').textContent=rm==='derive'?'Portfolio totals · Re-derive EIR':'Portfolio totals · System EIR';
calcRenderRecon('calcPortReconBody',CALC.portfolioTotals,false,rm);
$('calcPortReconWrap').classList.remove('hidden');
calcRenderPortfolio();
$('calcPgBar').classList.remove('hidden');
$('calcPortTblWrap').classList.remove('hidden');
}
function calcRenderCoverage(){
const total=CALC.accByNum.size;const processed=CALC.portfolio.length;
const parts=[`<span>Coverage <strong>${processed.toLocaleString()} / ${total.toLocaleString()}</strong></span>`];
const excl=[];
const rm=CALC.resultMethod||CALC.method;
if(CALC.excludedHP.length)excl.push(`<span>HP ${CALC.excludedHP.length.toLocaleString()}</span>`);
if(rm==='derive'&&CALC.excludedFlag.length)excl.push(`<span>Flag≠Y ${CALC.excludedFlag.length.toLocaleString()}</span>`);
if(CALC.negativeEir.length)excl.push(`<a onclick="calcOpenNegEirModal()">EIR&lt;0 ${CALC.negativeEir.length.toLocaleString()}</a>`);
if(excl.length)parts.push(`<span>Exclusions: ${excl.join(' <span class="calc-coverage-sep">·</span> ')}</span>`);
$('calcCoverage').innerHTML=parts.join('');
$('calcCoverage').classList.remove('hidden');
}
function calcRenderRecon(bodyId,r,singleModeShowEirRow,methodOverride){
const deriveRow=(methodOverride||CALC.method)==='derive';
const rows=[
['PV of cash flows',_cFmtN(r.pvCalc,2),_cFmtN(r.pvSys,2),_cFmtN(r.pvDiff,2),_cFmtPct(r.pvDiffPct,2)],
['EIR adjustment',_cFmtN(r.eirAdjCalc,2),_cFmtN(r.eirAdjSys,2),_cFmtN(r.eirDiff,2),_cFmtPct(r.eirDiffPct,2)]
];
if(deriveRow&&singleModeShowEirRow){
rows.push(['EIR rate',_cFmtPct(r.derivedEir,6),_cFmtPct(r.sysEir,6),(r.eirRateDiff>=0?'+':'')+Number(r.eirRateDiff).toFixed(6)+' pp','—']);
}
$(bodyId).innerHTML=rows.map(row=>'<tr>'+row.map(c=>`<td>${c}</td>`).join('')+'</tr>').join('');
}
const _CF_HEADS=['Period','Start Date','End Date','Rate 1','Rate 2','Days 1','Days 2','Year Fraction 1','Year Fraction 2','Opening Balance','Interest','Principal','Ending Balance','Cashflow Before Disc','Discount Factor','PV'];
function calcRenderCashflow(cashflow,totalPV){
$('calcCfHead').innerHTML=_CF_HEADS.map((h,i)=>`<th class="${i===0?'calc-sticky':''}">${h}</th>`).join('');
$('calcCfBody').innerHTML=cashflow.map(r=>`<tr>
<td class="calc-sticky" style="text-align:center;">${r.period}</td>
<td>${r.startDate}</td><td>${r.endDate}</td>
<td>${r.rate1!==''?parseFloat(r.rate1).toFixed(6):''}</td>
<td>${r.rate2!==''?parseFloat(r.rate2).toFixed(6):''}</td>
<td>${r.days1||''}</td><td>${r.days2>0?r.days2:''}</td>
<td>${r.yf1.toFixed(6)}</td><td>${r.yf2>0?r.yf2.toFixed(6):''}</td>
<td>${_cFmtN(r.opening,2)}</td><td>${_cFmtN(r.interest,2)}</td>
<td>${_cFmtN(r.principal,2)}</td><td>${_cFmtN(r.ending,2)}</td>
<td>${_cFmtN(r.cf,2)}</td><td>${r.df.toFixed(6)}</td><td>${_cFmtN(r.pv,2)}</td>
</tr>`).join('');
$('calcCfFoot').innerHTML=`<tr><td colspan="15" style="text-align:right;">Total PV</td><td>${_cFmtN(totalPV,2)}</td></tr>`;
}
function calcRenderPortfolio(){
const deriveEirOn=(CALC.resultMethod||CALC.method)==='derive';
const base=['Account','PV per Calc','N_PV_CASH_FLOWS_EIR','PV Diff (Amt)','PV Diff (%)'];
const eirCols=['EIR per Calc','N_IFRS9_EFF_INTEREST_RATE','EIR Diff'];
const tail=['EIR Adj per Calc','N_UNAMRT_FEES_EIR','EIR Adj Diff (Amt)','EIR Adj Diff (%)'];
const heads=deriveEirOn?[...base,...eirCols,...tail]:[...base,...tail];
const sortables={'PV Diff (Amt)':'pvDiff','PV Diff (%)':'pvDiffPct','EIR per Calc':'derivedEir','N_IFRS9_EFF_INTEREST_RATE':'sysEir','EIR Diff':'eirRateDiff','EIR Adj Diff (Amt)':'eirDiff','EIR Adj Diff (%)':'eirDiffPct'};
$('calcPortHead').innerHTML=heads.map((h,i)=>{
const fld=sortables[h];const cls=[i===0?'calc-sticky':''].filter(Boolean).join(' ');
const clk=fld?` class="${cls} calc-sortable" onclick="calcSortPortfolio('${fld}')"`:(cls?` class="${cls}"`:'');
const arrow=fld?' ↕':'';
return`<th${clk}>${h}${arrow}</th>`;
}).join('');
const total=Math.ceil(CALC.portfolio.length/CALC.perPage)||1;
CALC.page=Math.max(1,Math.min(CALC.page,total));
const start=(CALC.page-1)*CALC.perPage;
const slice=CALC.portfolio.slice(start,start+CALC.perPage);
$('calcPortBody').innerHTML=slice.map(r=>{
const fields=[`<td class="calc-sticky"><a onclick="calcDrillAccount('${r.acc}')">${r.acc}</a></td>`,
`<td>${_cFmtN(r.pvCalc,2)}</td>`,`<td>${_cFmtN(r.pvSys,2)}</td>`,
`<td>${_cFmtN(r.pvDiff,2)}</td>`,`<td>${_cFmtPct(r.pvDiffPct,2)}</td>`];
if(deriveEirOn)fields.push(`<td>${_cFmtPct(r.derivedEir,6).replace('%','')}</td>`,`<td>${_cFmtPct(r.sysEir,6).replace('%','')}</td>`,`<td>${_cFmtPct(r.eirRateDiff,6).replace('%','')}</td>`);
fields.push(`<td>${_cFmtN(r.eirAdjCalc,2)}</td>`,`<td>${_cFmtN(r.eirAdjSys,2)}</td>`,`<td>${_cFmtN(r.eirDiff,2)}</td>`,`<td>${_cFmtPct(r.eirDiffPct,2)}</td>`);
return'<tr>'+fields.join('')+'</tr>';
}).join('');
$('calcPgInfo').textContent=`Page ${CALC.page} of ${total} (${CALC.portfolio.length.toLocaleString()} total)`;
$('calcPgPrev').disabled=CALC.page===1;$('calcPgNext').disabled=CALC.page===total;
}
window.calcChangePage=function(d){CALC.page+=d;calcRenderPortfolio();};
window.calcSortPortfolio=function(field){
if(CALC.sort.field===field)CALC.sort.dir*=-1;else{CALC.sort.field=field;CALC.sort.dir=1;}
CALC.portfolio.sort((a,b)=>(a[field]-b[field])*CALC.sort.dir);
CALC.page=1;calcRenderPortfolio();
};
window.calcDrillAccount=function(acc){
CALC.cameFromPortfolio=true;
$('calcAcc').value=acc;calcSetScope('one');calcRunSingle(acc);
};
window.calcOpenNegEirModal=function(){$('calcNegEirTbody').innerHTML=CALC.negativeEir.map(a=>`<tr><td>${a}</td></tr>`).join('')||'<tr><td>No accounts.</td></tr>';$('calcNegEirModal').classList.add('open');};
window.calcOpenExcludedModal=function(kind){
const list=kind==='HP'?CALC.excludedHP:CALC.excludedFlag;
$('calcExclTitle').textContent=kind==='HP'?'Excluded — SG_HirePurchase':'Excluded — F_EIR_CALCULATION_FLAG ≠ Y';
$('calcExclTbody').innerHTML=list.map(a=>`<tr><td>${a}</td></tr>`).join('')||'<tr><td>No accounts.</td></tr>';
$('calcExcludedModal').classList.add('open');
};
window.calcExportSingle=function(){
if(!CALC.lastResult||!CALC.currentAcc)return;
const r=CALC.lastResult;
const rows=r.cashflow.map(cf=>({
Period:cf.period,'Start Date':cf.startDate,'End Date':cf.endDate,
'Rate 1':cf.rate1,'Rate 2':cf.rate2===''?null:cf.rate2,
'Days 1':cf.days1,'Days 2':cf.days2||null,
'Year Fraction 1':Number(cf.yf1.toFixed(6)),'Year Fraction 2':cf.yf2>0?Number(cf.yf2.toFixed(6)):null,
'Opening Balance':Number(cf.opening.toFixed(2)),'Interest':Number(cf.interest.toFixed(2)),
'Principal':Number(cf.principal.toFixed(2)),'Ending Balance':Number(cf.ending.toFixed(2)),
'Cashflow Before Disc':Number(cf.cf.toFixed(2)),'Discount Factor':Number(cf.df.toFixed(6)),
'PV':Number(cf.pv.toFixed(2))
}));
rows.push({Period:'',...{},'Discount Factor':'Total PV','PV':Number(r.pvCalc.toFixed(2))});
const ws=XLSX.utils.json_to_sheet(rows);
ws['!cols']=Object.keys(rows[0]||{}).map(k=>({wch:Math.max(k.length+2,15)}));
const wb=XLSX.utils.book_new();XLSX.utils.book_append_sheet(wb,ws,'Cashflow Schedule');
XLSX.writeFile(wb,`EIR_Schedule_${CALC.currentAcc}_${DU.fmtMY(CALC.month)}.xlsx`);
showToast('Exported ✓');
};
window.calcExportPortfolio=function(){
if(!CALC.portfolio.length)return;
const deriveEirOn=CALC.method==='derive';
const rows=CALC.portfolio.map(r=>{
const row={
'Account Number':r.acc,
'PV per Calc':Number(r.pvCalc.toFixed(2)),
'N_PV_CASH_FLOWS_EIR':Number(r.pvSys.toFixed(2)),
'PV Diff (Amt)':Number(r.pvDiff.toFixed(2)),
'PV Diff (%)':Number((r.pvDiffPct/100).toFixed(6))
};
if(deriveEirOn){
row['EIR per Calc']=Number(r.derivedEir.toFixed(6));
row['N_IFRS9_EFF_INTEREST_RATE']=Number(r.sysEir.toFixed(6));
row['EIR Diff']=Number(r.eirRateDiff.toFixed(6));
}
row['EIR Adj per Calc']=Number(r.eirAdjCalc.toFixed(2));
row['N_UNAMRT_FEES_EIR']=Number(r.eirAdjSys.toFixed(2));
row['EIR Adj Diff (Amt)']=Number(r.eirDiff.toFixed(2));
row['EIR Adj Diff (%)']=Number((r.eirDiffPct/100).toFixed(6));
return row;
});
const ws=XLSX.utils.json_to_sheet(rows);
ws['!cols']=Object.keys(rows[0]).map(k=>({wch:Math.max(k.length+2,16)}));
const wb=XLSX.utils.book_new();XLSX.utils.book_append_sheet(wb,ws,'Account Listing');
XLSX.writeFile(wb,`EIR_Account_Listing_${DU.fmtMY(CALC.month)}.xlsx`);
showToast('Exported ✓');
};
const _origRebuild=rebuildFromStore;
rebuildFromStore=async function(){await _origRebuild.apply(this,arguments);CALC._rateIdbCache.clear();if(!$('calcView').classList.contains('hidden'))calcSyncMonthPicker();};
document.addEventListener('keydown',e=>{
if(e.key==='Escape'){
if($('calcNegEirModal').classList.contains('open')){calcCloseNegEirModal();return;}
if($('calcExcludedModal').classList.contains('open')){calcCloseExcludedModal();return;}
if(CALC.view==='single'){calcBackFromSingle();return;}
}
});
$('calcAcc').addEventListener('keydown',e=>{if(e.key==='Enter'){e.preventDefault();calcRun();}});
$('calcAcc').addEventListener('input',()=>{calcUpdateRunBtn();calcUpdateHint();});
</script>
