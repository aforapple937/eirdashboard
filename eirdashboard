function renderStoredMonthsModal(accRows,manRows){
  const list=$('smList'),sum=$('smSummary');if(!list)return;
  if((!accRows||!accRows.length)&&(!manRows||!manRows.length)){list.innerHTML='<div class="sm-empty">Nothing cached yet. Use <strong>Load Data</strong> or press <strong>U</strong> to add manual adjustments.</div>';if(sum)sum.textContent='';return;}
  const parts=[];
  if(accRows&&accRows.length){
    accRows.sort((a,b)=>{const da=DU.parse(a.date),db=DU.parse(b.date);return(da?.getTime()||0)-(db?.getTime()||0);});
    parts.push('<div class="sm-sec-lbl">Account months (CSV)</div>');
    parts.push(accRows.map(r=>`<div class="sm-row"><span class="sm-name">${DU.fmtMY(r.date)}</span><span class="sm-cnt">${(r.rows?.length||0).toLocaleString()} accounts</span><button class="sm-del" onclick="deleteStoredMonth('${r.date}')" title="Delete ${DU.fmtMY(r.date)}">Remove</button></div>`).join(''));
  }
  if(manRows&&manRows.length){
    parts.push('<div class="sm-sec-lbl">Manual adjustments (JSON)</div>');
    const fieldSet=new Set();
    manRows.forEach(r=>{
      const d=r.data||{};
      if(d['1M SORA - USED']!==undefined||d['1M SORA - ACTUAL']!==undefined)fieldSet.add('SORA');
      ['HL','HP','Others'].forEach(p=>{if(d[p]&&Object.keys(d[p]).length)fieldSet.add(p);});
    });
    const fields=Array.from(fieldSet).join(', ')||'(empty)';
    parts.push(`<div class="sm-row sm-manual"><span class="sm-name">Manual</span><span class="sm-cnt">${fields}</span><button class="sm-del" onclick="deleteAllStoredManual()" title="Delete all manual adjustments">Remove</button></div>`);
  }
  list.innerHTML=parts.join('');
  const totalAcc=(accRows||[]).reduce((s,r)=>s+(r.rows?.length||0),0);
  const manCount=manRows?.length?1:0;
  if(sum)sum.textContent=`${accRows?.length||0} account month${(accRows?.length||0)!==1?'s':''} · ${totalAcc.toLocaleString()} accounts · ${manCount} manual entr${manCount!==1?'ies':'y'}`;
}
