window.saveManualEntry=async function(){
  const date=$('mmMonth').value;if(!date){showToast('Select a month first.');return;}
  const key=manualKeyForDate(date);const data={};
  const num=v=>{v=String(v??'').trim();if(v==='')return undefined;const n=parseFloat(v);return isNaN(n)?undefined:n;};
  const sU=$('mm-sora-used').value.trim(),sA=$('mm-sora-actual').value.trim();
  if(sU!=='')data['1M SORA - USED']=sU;
  if(sA!=='')data['1M SORA - ACTUAL']=sA;
  ['HL','HP','Others'].forEach(p=>{
    const entry={};const s=num($('mm-'+p+'-sora').value),a=num($('mm-'+p+'-ael').value),pnl=num($('mm-'+p+'-pnl').value);
    if(s!==undefined)entry['Change in SORA']=s;
    if(a!==undefined)entry['Change in AEL']=a;
    if(pnl!==undefined)entry['P&L']=pnl;
    if(Object.keys(entry).length)data[p]=entry;
  });
  try{await IDB.putMan(key,data);}catch(err){console.error(err);showToast('Save failed: '+err.message);return;}
  window.parsedManualDataGlobal[key]=data;
  await renderStoredMonthsPanel();
  updateDashboardView();renderSoraChart();renderSoraTable();
  updateManualIndicator();
  showToast('Saved '+DU.fmtMY(date)+' ✓');
